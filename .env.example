# Optional stable Google Scholar backend
SERPAPI_KEY=

# Optional Semantic Scholar higher-rate API key
SEMANTIC_SCHOLAR_API_KEY=

# Recommended for polite OpenAlex API use
OPENALEX_MAILTO=

# Optional direct SMTP sending
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Optional metadata enrichment
# Needed for Unpaywall OA/PDF metadata requests
UNPAYWALL_EMAIL=

# Optional Elsevier/ScienceDirect enrichment; needed for some ScienceDirect abstracts
ELSEVIER_API_KEY=
